<!DOCTYPE html>
<html>
<head>
  <title>My Orders | Smart Fashion</title>
  <link rel="stylesheet" href="/css/style.css">
  <style>
    .orders-container {
      max-width: 1200px;
      margin: 2rem auto;
      padding: 0 20px;
    }
    
    .orders-container h1 {
      margin-bottom: 2rem;
      background: linear-gradient(135deg, #667eea, #764ba2);
      -webkit-background-clip: text;
      background-clip: text;
      -webkit-text-fill-color: transparent;
    }
    
    .order-card {
      background: #1a1a2e;
      border-radius: 15px;
      margin-bottom: 1.5rem;
      overflow: hidden;
      border: 1px solid rgba(102,126,234,0.2);
      transition: transform 0.3s;
    }
    
    .order-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 10px 30px rgba(0,0,0,0.3);
    }
    
    .order-header {
      background: #0a0a0a;
      padding: 1rem 1.5rem;
      display: flex;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 1rem;
      border-bottom: 1px solid #333;
    }
    
    .order-status {
      padding: 4px 12px;
      border-radius: 20px;
      font-size: 0.8rem;
      font-weight: bold;
    }
    
    .status-pending { background: #f39c12; color: #000; }
    .status-processing { background: #3498db; color: white; }
    .status-shipped { background: #9b59b6; color: white; }
    .status-delivered { background: #27ae60; color: white; }
    .status-cancelled { background: #e74c3c; color: white; }
    
    .order-items {
      padding: 1.5rem;
    }
    
    .order-item {
      display: flex;
      gap: 1rem;
      padding: 0.8rem 0;
      border-bottom: 1px solid #333;
      align-items: center;
    }
    
    .order-item:last-child {
      border-bottom: none;
    }
    
    .order-item img {
      width: 60px;
      height: 60px;
      object-fit: cover;
      border-radius: 10px;
    }
    
    .order-item-info {
      flex: 1;
    }
    
    .order-item-name {
      font-weight: bold;
      margin-bottom: 0.25rem;
    }
    
    .order-item-price {
      color: #667eea;
      font-size: 0.9rem;
    }
    
    .order-footer {
      padding: 1rem 1.5rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      border-top: 1px solid #333;
      background: #0a0a0a;
    }
    
    .order-total {
      font-size: 1.2rem;
      font-weight: bold;
    }
    
    .order-total span {
      color: #667eea;
      font-size: 1.3rem;
    }
    
    .btn-cancel {
      background: #e74c3c;
      color: white;
      border: none;
      padding: 8px 20px;
      border-radius: 20px;
      cursor: pointer;
      transition: all 0.3s;
      font-weight: bold;
    }
    
    .btn-cancel:hover:not(:disabled) {
      transform: translateY(-2px);
      box-shadow: 0 5px 15px rgba(231,76,60,0.4);
    }
    
    .btn-cancel:disabled {
      opacity: 0.5;
      cursor: not-allowed;
    }
    
    .btn-view {
      background: linear-gradient(135deg, #667eea, #764ba2);
      color: white;
      border: none;
      padding: 8px 20px;
      border-radius: 20px;
      cursor: pointer;
      transition: all 0.3s;
      margin-left: 10px;
    }
    
    .btn-view:hover {
      transform: translateY(-2px);
    }
    
    .no-orders {
      text-align: center;
      padding: 4rem;
      background: #1a1a2e;
      border-radius: 15px;
    }
    
    .no-orders p {
      color: #888;
      margin-bottom: 1rem;
    }
    
    .no-orders a {
      color: #667eea;
      text-decoration: none;
    }
    
    @media (max-width: 768px) {
      .order-header {
        flex-direction: column;
      }
      
      .order-footer {
        flex-direction: column;
        gap: 1rem;
        text-align: center;
      }
      
      .order-actions {
        width: 100%;
      }
      
      .btn-cancel, .btn-view {
        width: 100%;
        margin: 5px 0;
      }
    }
  </style>
</head>
<body>
  <%- include('../partials/navbar') %>
  
  <div class="orders-container">
    <h1>My Orders</h1>
    
    <% if (orders && orders.length > 0) { %>
      <% orders.forEach(order => { %>
        <div class="order-card" data-order-id="<%= order._id %>">
          <div class="order-header">
            <div>
              <strong>Order #<%= order._id.toString().slice(-8) %></strong>
            </div>
            <div>Placed on: <%= new Date(order.createdAt).toLocaleDateString() %></div>
            <div>
              Status: 
              <span class="order-status status-<%= order.status %>">
                <%= order.status.toUpperCase() %>
              </span>
            </div>
          </div>
          
          <div class="order-items">
            <% order.items.forEach(item => { %>
              <div class="order-item">
                <img src="<%= item.image || '/images/default.jpg' %>" alt="<%= item.name %>">
                <div class="order-item-info">
                  <div class="order-item-name"><%= item.name %></div>
                  <div class="order-item-price">$<%= item.price %> x <%= item.quantity %></div>
                </div>
                <div style="font-weight: bold;">$<%= (item.price * item.quantity).toFixed(2) %></div>
              </div>
            <% }) %>
          </div>
          
          <div class="order-footer">
            <div class="order-total">
              Total: <span>$<%= order.totalPrice.toFixed(2) %></span>
            </div>
            <div class="order-actions">
              <% if (order.status === 'pending') { %>
                <button class="btn-cancel" onclick="cancelOrder('<%= order._id %>')">
                  Cancel Order
                </button>
              <% } %>
              <button class="btn-view" onclick="viewOrder('<%= order._id %>')">
                View Details
              </button>
            </div>
          </div>
        </div>
      <% }) %>
    <% } else { %>
      <div class="no-orders">
        <p>📦 You haven't placed any orders yet</p>
        <a href="/products">Start Shopping →</a>
      </div>
    <% } %>
  </div>
  
  <script>
    async function cancelOrder(orderId) {
      if (!confirm('Are you sure you want to cancel this order? This action cannot be undone.')) {
        return;
      }
      
      const token = localStorage.getItem('token');
      
      try {
        const response = await fetch(`/api/orders/${orderId}/cancel`, {
          method: 'PUT',
          headers: {
            'Content-Type': 'application/json',
            'Authorization': `Bearer ${token}`
          },
          body: JSON.stringify({ reason: 'Cancelled by user' })
        });
        
        const data = await response.json();
        
        if (data.success) {
          alert('Order cancelled successfully!');
          // Reload the page to show updated status
          window.location.reload();
        } else {
          alert(data.message || 'Failed to cancel order');
        }
      } catch (error) {
        console.error('Error cancelling order:', error);
        alert('Error cancelling order. Please try again.');
      }
    }
    
    function viewOrder(orderId) {
      window.location.href = `/order/${orderId}`;
    }
  </script>
</body>
</html>