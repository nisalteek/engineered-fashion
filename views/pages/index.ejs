<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>🚀ENGINEERED FASHION</title>
  <link rel="stylesheet" href="/css/style.css">

  <!-- AOS Animation -->
  <link href="https://unpkg.com/aos@2.3.4/dist/aos.css" rel="stylesheet">
</head>

<body>

<!-- 🔹 NAVBAR >
<%- include('../partials/navbar') %>

<!-- 🔹 HERO SECTION -->
<section class="hero">
  <div class="hero-text" data-aos="fade-up">
    <h1>ENGINEERED FASHION</h1>
    <p>Smart clothing powered by innovation</p>
    <a href="/products" class="btn">Explore Collection</a>
  </div>
</section>

<!-- 🔹 FEATURED PRODUCTS -->
<section class="products">
  <h2 data-aos="fade-up">Featured Collection</h2>

  <div class="product-grid">
    <% if (products && products.length > 0) { %>
      <% products.forEach(product => { %>
        <div class="product-card" data-aos="zoom-in">
          <img src="<%= product.image || '/images/p1.jpg' %>" alt="<%= product.name %>">
          <h3><%= product.name %></h3>
          <p class="price">$<%= product.price %></p>
          <a href="/products/<%= product._id %>" class="btn-view">View Details</a>
        </div>
      <% }) %>
    <% } else { %>
      <div class="no-products">
        <p>No products available yet. Check back soon!</p>
      </div>
    <% } %>
  </div>
</section>

<!-- 🔹 PROMOTION BANNER-->
<section class="promo-banner" data-aos="fade-up">
  <div class="promo-banner-content">
    <% if (typeof promotions !== 'undefined' && promotions && promotions.length > 0) { %>
      <% var bestPromo = promotions[0]; %>
      <div class="promo-tag">🔥 LIMITED TIME OFFER</div>
      <h2 class="promo-title"><%= bestPromo.title %></h2>
      <p class="promo-desc"><%= bestPromo.description || 'Limited time offer on selected items!' %></p>
      
      <div class="promo-discount">
        <div class="discount-circle">
          <span class="discount-percent"><%= bestPromo.discountPercentage %>%</span>
          <span class="discount-label">OFF</span>
        </div>
      </div>
      
      <div class="promo-validity">
        <span class="validity-icon">⏰</span>
        <span class="validity-text">Valid until: <%= new Date(bestPromo.endDate).toLocaleDateString() %></span>
      </div>
      
      <a href="/products" class="promo-btn">
        <span>Shop Now</span>
        <span class="btn-arrow">→</span>
      </a>
    <% } else { %>
      <div class="promo-tag">🎉 SPECIAL OFFER</div>
      <h2 class="promo-title">20% OFF with Bank Cards 💳</h2>
      <p class="promo-desc">Limited time offer on all products</p>
      
      <div class="promo-discount">
        <div class="discount-circle">
          <span class="discount-percent">20%</span>
          <span class="discount-label">OFF</span>
        </div>
      </div>
      
      <div class="promo-validity">
        <span class="validity-icon">⏰</span>
        <span class="validity-text">Limited time offer - Don't miss out!</span>
      </div>
      
      <a href="/products" class="promo-btn">
        <span>Shop Now</span>
        <span class="btn-arrow">→</span>
      </a>
    <% } %>
  </div>
</section>
<!-- 🔹 CONTACT SECTION -->
<section class="contact-section" data-aos="fade-up">
  <h2>Get In Touch</h2>
  <p class="contact-subtitle">We'd love to hear from you</p>
  
  <div class="contact-grid">
    <div class="contact-card">
      <div class="contact-icon">📍</div>
      <h3>Visit Us</h3>
      <p>123 Fashion Avenue,<br>Colombo 03, Sri Lanka</p>
    </div>
    
    <div class="contact-card">
      <div class="contact-icon">📞</div>
      <h3>Call Us</h3>
      <p>+94 11 234 5678</p>
      <p>+94 77 123 4567</p>
      <p class="fax">Fax: +94 11 234 5679</p>
    </div>
    
    <div class="contact-card">
      <div class="contact-icon">✉️</div>
      <h3>Email Us</h3>
      <p>info@engineeredfashion.com</p>
      <p>support@engineeredfashion.com</p>
      <p>sales@engineeredfashion.com</p>
    </div>
    
    <div class="contact-card">
      <div class="contact-icon">🕒</div>
      <h3>Business Hours</h3>
      <p>Monday - Friday: 9am - 7pm</p>
      <p>Saturday: 10am - 5pm</p>
      <p>Sunday: Closed</p>
    </div>
  </div>
  
 
</section>

<!-- 🔹 FOOTER -->
<footer>
  <p>© 2026 SmartWear</p>
</footer>

<!-- Floating Chatbot Icon -->
<div class="chatbot-icon" id="chatbotIcon">
  <div class="chatbot-icon-inner">💬</div>
</div>

<!-- Chatbot Window (Hidden by default) -->
<div class="chatbot-window" id="chatbotWindow">
  <div class="chatbot-header">
    <span>AI Assistant</span>
    <button class="chatbot-close" id="chatbotClose">✕</button>
  </div>
  <div class="chatbot-messages" id="chatbotMessages">
    <div class="message bot">
      Hello! 👋 I'm your AI assistant. How can I help you today?
    </div>
  </div>
  <div class="chatbot-input-area">
    <input type="text" id="chatbotInput" placeholder="Type your message..." autocomplete="off">
    <button id="chatbotSend">Send</button>
  </div>
</div>

<script src="https://unpkg.com/aos@2.3.4/dist/aos.js"></script>
<script src="/js/chatbot.js"></script>
<script>
  AOS.init();
</script>
</body>
</html>