<!DOCTYPE html>
<html>
<head>
  <title>Special Offers | ENGINEERED FASHION</title>
  <link rel="stylesheet" href="/css/style.css">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      background: #0a0a0a;
      color: white;
    }

    /* Hero Section */
    .promo-hero {
      background: linear-gradient(135deg, #0f0f1a 0%, #1a1a2e 100%);
      padding: 6rem 2rem;
      text-align: center;
      position: relative;
      overflow: hidden;
      border-bottom: 1px solid rgba(102, 126, 234, 0.2);
    }

    .promo-hero h1 {
      font-size: 3.5rem;
      margin-bottom: 1rem;
      background: linear-gradient(135deg, #ffffff, #667eea);
      -webkit-background-clip: text;
      background-clip: text;
      -webkit-text-fill-color: transparent;
      letter-spacing: -0.5px;
    }

    .promo-hero p {
      font-size: 1.2rem;
      opacity: 0.8;
      color: #aaa;
    }

    /* Promotions Section */
    .promotions-section {
      max-width: 1200px;
      margin: 0 auto;
      padding: 4rem 2rem;
    }

    .promotions-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
      gap: 2rem;
    }

    .promotion-card {
      background: linear-gradient(135deg, #111111, #0a0a0a);
      border-radius: 20px;
      overflow: hidden;
      transition: all 0.4s ease;
      border: 1px solid rgba(102, 126, 234, 0.15);
      position: relative;
    }

    .promotion-card:hover {
      transform: translateY(-8px);
      border-color: rgba(102, 126, 234, 0.4);
      box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
    }

    .promotion-image {
      width: 100%;
      height: 220px;
      object-fit: cover;
      transition: transform 0.5s ease;
    }

    .promotion-card:hover .promotion-image {
      transform: scale(1.05);
    }

    .discount-badge {
      position: absolute;
      top: 1rem;
      right: 1rem;
      background: linear-gradient(135deg, #e74c3c, #c0392b);
      padding: 8px 16px;
      border-radius: 30px;
      font-weight: bold;
      font-size: 1.1rem;
      box-shadow: 0 5px 15px rgba(0,0,0,0.3);
      z-index: 2;
      display: flex;
      flex-direction: column;
      align-items: center;
      line-height: 1.2;
    }

    .discount-badge .percent {
      font-size: 1.3rem;
    }

    .discount-badge .off {
      font-size: 0.7rem;
      opacity: 0.9;
    }

    .promotion-info {
      padding: 1.5rem;
    }

    .promotion-title {
      font-size: 1.3rem;
      font-weight: 700;
      margin-bottom: 0.5rem;
      color: white;
    }

    .promotion-description {
      color: #888;
      font-size: 0.9rem;
      line-height: 1.5;
      margin: 0.5rem 0;
    }

    .promotion-dates {
      display: flex;
      justify-content: space-between;
      margin: 1rem 0;
      padding: 0.5rem 0;
      border-top: 1px solid rgba(255,255,255,0.08);
      border-bottom: 1px solid rgba(255,255,255,0.08);
      font-size: 0.8rem;
      color: #666;
    }

    .promotion-dates span {
      display: flex;
      align-items: center;
      gap: 5px;
    }

    .active-banner {
      background: rgba(39, 174, 96, 0.15);
      border: 1px solid rgba(39, 174, 96, 0.3);
      padding: 5px 12px;
      border-radius: 20px;
      font-size: 0.7rem;
      color: #27ae60;
      display: inline-flex;
      align-items: center;
      gap: 5px;
      margin-top: 0.5rem;
    }

    .btn-shop {
      width: 100%;
      background: linear-gradient(135deg, #667eea, #764ba2);
      color: white;
      border: none;
      padding: 12px;
      border-radius: 12px;
      font-size: 1rem;
      font-weight: 600;
      cursor: pointer;
      margin-top: 1rem;
      transition: all 0.3s ease;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
    }

    .btn-shop:hover {
      transform: translateY(-2px);
      box-shadow: 0 5px 15px rgba(102,126,234,0.4);
      gap: 12px;
    }

    .no-promotions {
      text-align: center;
      padding: 4rem;
      background: linear-gradient(135deg, #111, #0a0a0a);
      border-radius: 20px;
      border: 1px solid rgba(102,126,234,0.15);
    }

    .no-promotions h3 {
      font-size: 1.5rem;
      margin-bottom: 1rem;
      background: linear-gradient(135deg, #fff, #888);
      -webkit-background-clip: text;
      background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    .no-promotions p {
      color: #888;
      margin-bottom: 1.5rem;
    }

    .no-promotions a {
      color: #667eea;
      text-decoration: none;
      font-weight: 600;
    }

    @media (max-width: 768px) {
      .promo-hero {
        padding: 4rem 1.5rem;
      }
      
      .promo-hero h1 {
        font-size: 2rem;
      }
      
      .promo-hero p {
        font-size: 1rem;
      }
      
      .promotions-section {
        padding: 2rem 1rem;
      }
      
      .promotions-grid {
        grid-template-columns: 1fr;
        gap: 1.5rem;
      }
    }
  </style>
</head>
<body>

<%- include('../partials/navbar') %>

<!-- Promotions Hero -->
<section class="promo-hero">
  <h1>✨ Exclusive Offers</h1>
  <p>Discover limited-time deals on engineered fashion</p>
</section>

<!-- Promotions Section -->
<section class="promotions-section">
  <% if (promotions && promotions.length > 0) { %>
    <div class="promotions-grid">
      <% promotions.forEach((promo) => { %>
        <div class="promotion-card">
          <img src="<%= promo.image || '/images/promo-default.jpg' %>" alt="<%= promo.title %>" class="promotion-image" onerror="this.src='/images/promo-default.jpg'">
          <div class="discount-badge">
            <span class="percent"><%= promo.discountPercentage %>%</span>
            <span class="off">OFF</span>
          </div>
          <div class="promotion-info">
            <div class="promotion-title"><%= promo.title %></div>
            <div class="promotion-description"><%= promo.description || 'Special offer on selected items. Limited time only.' %></div>
            <div class="promotion-dates">
              <span>📅 Starts: <%= new Date(promo.startDate).toLocaleDateString() %></span>
              <span>⏰ Ends: <%= new Date(promo.endDate).toLocaleDateString() %></span>
            </div>
            <div class="active-banner">
              <span>●</span> ACTIVE OFFER
            </div>
            <button class="btn-shop" onclick="window.location.href='/products'">
              SHOP NOW <span>→</span>
            </button>
          </div>
        </div>
      <% }) %>
    </div>
  <% } else { %>
    <div class="no-promotions">
      <h3>✨ Coming Soon</h3>
      <p>Exciting offers are on their way. Stay tuned!</p>
      <a href="/products">Browse Products →</a>
    </div>
  <% } %>
</section>

</body>
</html>