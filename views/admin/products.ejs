<%- include('partials/header', { title: 'Products', currentPage: 'products' }) %>

<div class="page-header" style="display: flex; justify-content: space-between; align-items: center;">
  <div>
    <h1>Product Management</h1>
    <p>Manage your product catalog</p>
  </div>
  <a href="/admin/products/create" class="btn-view" style="padding: 10px 20px; background: #667eea; color: white;">+ Add New Product</a>
</div>

<div class="data-table">
  <table>
    <thead>
      <tr>
        <th>Image</th>
        <th>Product Name</th>
        <th>Price</th>
        <th>Category</th>
        <th>Stock</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% if (products && products.length > 0) { %>
        <% products.forEach(product => { %>
          <tr>
            <td>
              <img src="<%= product.image || '/images/default.jpg' %>" alt="<%= product.name %>" style="width: 50px; height: 50px; object-fit: cover; border-radius: 8px;">
            </td>
            <td><strong><%= product.name %></strong></td>
            <td>$<%= product.price %></td>
            <td><span style="background: rgba(102,126,234,0.2); padding: 4px 12px; border-radius: 20px;"><%= product.category || 'Uncategorized' %></span></td>
            <td><%= product.stock || 0 %> units</td>
            <td>
              <a href="/admin/products/<%= product._id %>/edit" class="btn-edit" style="margin-right: 5px;">✏️ Edit</a>
              <a href="/admin/products/<%= product._id %>/delete" class="btn-edit" style="background: rgba(231,76,60,0.2); color: #e74c3c;" onclick="return confirm('Are you sure you want to delete this product?')">🗑️ Delete</a>
            </td>
          </tr>
        <% }) %>
      <% } else { %>
        <tr>
          <td colspan="6" style="text-align: center; padding: 3rem;">No products found. <a href="/admin/products/create" style="color: #667eea;">Create your first product →</a></td>
        </tr>
      <% } %>
    </tbody>
  </table>
</div>

</main>
</div>
</body>
</html>