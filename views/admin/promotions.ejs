<%- include('partials/header', { title: 'Promotions', currentPage: 'promotions' }) %>

<div class="page-header" style="display: flex; justify-content: space-between; align-items: center;">
  <div>
    <h1>Promotion Management</h1>
    <p>Manage special offers and discounts</p>
  </div>
  <a href="/admin/promotions/create" class="btn-view" style="padding: 10px 20px; background: #667eea; color: white;">+ Add New Promotion</a>
</div>

<div class="data-table">
  <table>
    <thead>
      <tr>
        <th>Title</th>
        <th>Discount</th>
        <th>Period</th>
        <th>Status</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% if (promotions && promotions.length > 0) { %>
        <% promotions.forEach(promo => { %>
          <tr>
            <td><strong><%= promo.title %></strong><br><span style="font-size: 0.75rem; color: #888;"><%= promo.description %></span></td>
            <td><span style="background: #e74c3c; padding: 4px 12px; border-radius: 20px; font-weight: bold;"><%= promo.discountPercentage %>% OFF</span></td>
            <td style="font-size: 0.875rem;">
              <%= new Date(promo.startDate).toLocaleDateString() %><br>
              → <%= new Date(promo.endDate).toLocaleDateString() %>
            </td>
            <td>
              <% if (promo.isActive) { %>
                <span class="status-badge status-delivered">ACTIVE</span>
              <% } else { %>
                <span class="status-badge status-cancelled">INACTIVE</span>
              <% } %>
            </td>
            <td>
              <a href="/admin/promotions/<%= promo._id %>/edit" class="btn-edit" style="margin-right: 5px;">✏️ Edit</a>
              <a href="/admin/promotions/<%= promo._id %>/delete" class="btn-edit" style="background: rgba(231,76,60,0.2); color: #e74c3c;" onclick="return confirm('Are you sure you want to delete this promotion?')">🗑️ Delete</a>
            </td>
          </tr>
        <% }) %>
      <% } else { %>
        <tr>
          <td colspan="5" style="text-align: center; padding: 3rem;">No promotions found. <a href="/admin/promotions/create" style="color: #667eea;">Create your first promotion →</a></td>
        </tr>
      <% } %>
    </tbody>
  </table>
</div>

</main>
</div>
</body>
</html>